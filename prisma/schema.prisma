// Prisma 7: connection URL lives in prisma.config.ts (Migrate) and is passed
// to the PrismaClient constructor via the @prisma/adapter-pg adapter at runtime.

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// Persistent analysis cache — survives server restarts and is shared across instances.
// The in-memory cache (lib/cache.ts) is the L1 layer; this is L2.
model CachedAnalysis {
  id         String   @id @default(cuid())
  imdbId     String   @unique
  movieTitle String
  data       String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([expiresAt])
}
